# Copy this file to .env at the repository root (not inside backend/)
# and fill in real local values. Never commit the real .env file.

# PostgreSQL connection used by the running Flask app
DATABASE_URL=postgresql+psycopg://proppulse:your_local_password@localhost:5432/proppulse_dev

# Separate PostgreSQL database used ONLY by the test suite.
# Keeping this separate from DATABASE_URL prevents pytest runs from
# ever creating/dropping tables against real development data.
TEST_DATABASE_URL=postgresql+psycopg://proppulse:your_local_password@localhost:5432/proppulse_test

# Redis connection, used for caching, rate limiting, and token
# revocation lookups.
REDIS_URL=redis://localhost:6379/0

# development | testing | staging | production
FLASK_ENV=development

# Used to sign Flask sessions and JWTs. Generate a real one locally
# with: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER reuse this value across environments, and never commit a
# real SECRET_KEY to version control.
SECRET_KEY=replace_with_a_generated_secret

# Postgres password used by docker-compose.yml at the repo root.
POSTGRES_PASSWORD=your_local_password
